class Solution {
public:
    int minSwaps(vector<int>& nums, vector<int>& forbidden) {
        int n=nums.size();
        mii numfreq;
        mii forfreq;
        mii bad_cnt;
        int k=0;
        for(int x:forbidden)forfreq[x]++;
        fr(i,0,n){
            numfreq[nums[i]]++;
            if(nums[i]==forbidden[i]){
                k++;
                bad_cnt[nums[i]]++;
            }
        }
        for(auto &[val,cnt]:numfreq){
            if(cnt+forfreq[val]>n)return -1;
        }
        if(k==0)return 0;
        int maxi=0;
        for(auto & [val, cnt] : bad_cnt) {
            maxi = max(maxi, cnt);
        }
        return max(maxi, (k + 1) / 2);

    }
};
