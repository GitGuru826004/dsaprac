int binary_exp(int n,int x){
    if(x==0) return 1;
    else if(x%2==0) return binary_exp(n*n,x/2);
    else return n*binary_exp(n*n,x/2);
}
int fact(int n){
    if(n==1) return 1;
    else return n*fact(n-1);
}
