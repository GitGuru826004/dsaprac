vi sievespf(int n){
    vi spf(n+1);
    for (int i=1;i<=n;i++)spf[i]=i;
    for(int i=2;i*i<=n;i++){
        if(spf[i]==i){
            for(int j=i*i;j<=n;j+=i){
                if(spf[j]==j)spf[j]=i;
            }
        }
    }
    return spf;
}

mii primefactorization(int n,vi &spf){
    mii freq;
    while(n > 1 && n < spf.size()){
        freq[spf[n]]++;
        n /= spf[n];
    }
    for (int i = 2; i * i <= n; ++i) {
        while (n % i == 0) {
            freq[i]++;
            n /= i;
        }
    }
    if (n > 1) freq[n]++;
    return freq;
}

