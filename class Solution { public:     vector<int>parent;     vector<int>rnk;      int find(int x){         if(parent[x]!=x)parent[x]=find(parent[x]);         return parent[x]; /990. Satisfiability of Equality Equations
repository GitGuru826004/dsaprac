class Solution {
public:
    vector<int>parent;
    vector<int>rnk;

    int find(int x){
        if(parent[x]!=x)parent[x]=find(parent[x]);
        return parent[x]; //path compression
    }

    void Unite(int x,int y){
        int x_parent=find(x);
        int y_parent=find(y);
        if(x_parent==y_parent)return;
        if(rnk[x_parent]>rnk[y_parent])parent[y_parent]=x_parent;
        else if(rnk[x_parent]<rnk[y_parent])parent[x_parent]=y_parent;
        else {
            parent[x_parent]=y_parent;
            rnk[y_parent]++;
        }
    }

    bool equationsPossible(vector<string>& equations) {
        parent.resize(26);
        rnk.resize(26,0);
        for(int i=0;i<26;i++)parent[i]=i;
        for(string e:equations){
            if(e[1]=='='){
                Unite(e[0]-'a',e[3]-'a');
            }
        }
        for(string e:equations){
            if(e[1]=='!'){
                if(find(e[0]-'a') == find(e[3]-'a')) return false;
            }
        }
        return true;
    }
};

